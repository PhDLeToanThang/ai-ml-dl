   "source": [
    "## 10. Machine Learning - Feature Engineering for Prediction"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create features for each draw\ndef create_features_for_prediction(df, number_cols, look_back=10):\n",
    "    \"\"\"\n",
    "    Create features based on recent history and statistical properties\n",
    "    \"\"\"\n",
    "    X = []\n",
    "    y = []\n",
    "    \n",
    "    for i in range(look_back, len(df) - 1):\n",
    "        # Historical data\n",
    "        history = df.iloc[i-look_back:i][number_cols].values.flatten()\n",
    "        history = history[~np.isnan(history)].astype(int)\n",
    "        \n",
    "        # Features\n",
    "        features = []\n",
    "        \n",
    "        # 1. Frequency of numbers in last look_back draws\n",
    "        freq_vec = np.zeros(45)\n",
    "        for num in history:\n",
    "            freq_vec[num-1] += 1\n",
    "        \n",
    "        # 2. Gap analysis features\n",
    "        gap_vec = np.zeros(45)\n",
    "        for num in range(1, 46):\n",
    "            last_idx = -1\n",
    "            for j in range(i-1, -1, -1):\n",
    "                if num in df.iloc[j][number_cols].values:\n",
    "                    last_idx = j\n",
    "                    break\n",
    "            gap_vec[num-1] = i - last_idx if last_idx >= 0 else i + 1\n",
    "        \n",
    "        # Combine features\n",
    "        combined_features = np.concatenate([freq_vec, gap_vec])\n",
    "        X.append(combined_features)\n",
    "        \n",
    "        # Target: numbers in next draw\n",
    "        next_numbers = df.iloc[i+1][number_cols].values\n",
    "        next_numbers = next_numbers[~np.isnan(next_numbers)].astype(int)\n",
    "        \n",
    "        target_vec = np.zeros(45)\n",
    "        for num in next_numbers:\n",
    "            target_vec[num-1] = 1\n",
    "        \n",
    "        y.append(target_vec)\n",
    "    \n",
    "    return np.array(X), np.array(y)\n",
    "\n",
    "print(\"Creating feature matrix for machine learning...\")\n",
    "X, y = create_features_for_prediction(df, number_columns, look_back=10)\n",
    "\n",
    "print(f\"Feature matrix shape: {X.shape}\")\n",
    "print(f\"Target shape: {y.shape}\")\n",
    "print(f\"Training samples: {len(X)}\")\n",
    "print(\"✓ Features created successfully\")"
   ]
  },
