    "# Save detailed statistics to CSV files\n",
    "\n",
    "# 1. Frequency statistics\n",
    "freq_df_export = freq_df.sort_values('Frequency', ascending=False)\n",
    "freq_df_export.to_csv(r'C:\\Python311\\m6b45\\frequency_analysis.csv', index=False)\n",
    "print(\"✓ Frequency analysis exported to: frequency_analysis.csv\")\n",
    "\n",
    "# 2. Gap analysis statistics\n",
    "gap_df_export = gap_df.sort_values('gap_since_last', ascending=False)\n",
    "gap_df_export.to_csv(r'C:\\Python311\\m6b45\\gap_analysis.csv', index=False)\n",
    "print(\"✓ Gap analysis exported to: gap_analysis.csv\")\n",
    "\n",
    "# 3. Prediction results\n",
    "prediction_results = pd.DataFrame({\n",
    "    'Method': list(all_predictions.keys()),\n",
    "    'Predicted_Numbers': [','.join(map(str, nums)) for nums in all_predictions.values()]\n",
    "})\n",
    "prediction_results.to_csv(r'C:\\Python311\\m6b45\\predictions.csv', index=False)\n",
    "print(\"✓ Predictions exported to: predictions.csv\")\n",
    "\n",
    "# 4. Top pairs\n",
    "top_pairs_df = pd.DataFrame([\n",
    "    {'Pair': f\"{pair[0]}-{pair[1]}\", 'Count': count}\n",
    "    for pair, count in top_pairs\n",
    "])\n",
    "top_pairs_df.to_csv(r'C:\\Python311\\m6b45\\top_pairs.csv', index=False)\n",
    "print(\"✓ Top pairs exported to: top_pairs.csv\")\n",
    "\n",
    "# 5. Model performance\n",
    "model_performance = pd.DataFrame([\n",
