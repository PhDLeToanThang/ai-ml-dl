   "metadata": {},
   "source": [
    "## 12. Ensemble Prediction for Next Draw"
   ]
  },
  {
   "cell_type": {"  "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Prepare features for latest draw\nlatest_idx = len(df) - 1\nlook_back = 10\n",
    "\nif latest_idx >= look_back:\n",
    "    # Get historical data\n",
    "    history = df.iloc[latest_idx-look_back+1:latest_idx+1][number_columns].values.flatten()\n",
    "    history = history[~np.isnan(history)].astype(int)\n",
    "    \n",
    "    # Frequency features\n",
    "    freq_vec = np.zeros(45)\n",
    "    for num in history:\n",
    "        freq_vec[num-1] += 1\n",
    "    \n",
    "    # Gap features\n",
    "    gap_vec = np.zeros(45)\n",
    "    for num in range(1, 46):\n",
    "        last_idx = -1\n",
    "        for j in range(latest_idx, -1, -1):\n",
    "            if num in df.iloc[j][number_columns].values:\n",
    "                last_idx = j\n",
    "                break\n",
    "        gap_vec[num-1] = latest_idx - last_idx if last_idx >= 0 else latest_idx + 1\n",
    "    \n",
    "    X_latest = np.concatenate([freq_vec, gap_vec]).reshape(1, -1)\n",
    "    X_latest_scaled = scaler.transform(X_latest)\n",
    "    \n",
    "    # Get predictions from all models\n",
    "    print(\"\\n=== PREDICTIONS FOR NEXT DRAW ===\")\n",
    "    print(f\"\\nBased on draws up to {df.iloc[latest_idx]['Ngày']} (Draw #{df.iloc[latest_idx]['Kỳ']})\")\n",
    "    \n",
    "    # Ensemble voting\n",
    "    ensemble_prediction = np.zeros(45)\n",
    "    \n",
    "    for name, model in models.items():\n",
    "        if name == 'Neural Network':\n",
    "            pred = model.predict_proba(X_latest_scaled)[0]\n",
    "        else:\n",
    "            pred = model.predict_proba(X_latest)[0]\n",
    "        \n",
    "        ensemble_prediction += pred\n",
    "        \n",
    "        # Top predictions from this model\n",
    "        top_5_indices = np.argsort(pred)[-5:][::-1]\n",
    "        top_5_numbers = [i+1 for i in top_5_indices]\n",
    "        print(f\"\\n{name} - Top 5: {top_5_numbers}\")\n",
    "    \n",
    "    # Normalize ensemble\n",
    "    ensemble_prediction /= len(models)\n",
    "    \n",
    "    # Get top 6 and additional candidates\n",
    "    top_6_indices = np.argsort(ensemble_prediction)[-6:][::-1]\n",
    "    top_12_indices = np.argsort(ensemble_prediction)[-12:][::-1]\n",
    "    \n",
    "    predicted_numbers = sorted([i+1 for i in top_6_indices])\n",
    "    predicted_numbers_12 = sorted([i+1 for i in top_12_indices])\n",
    "    \n",
    "    print(f\"\\n{'='*50}\")\n",
    "    print(f\"ENSEMBLE PREDICTION (Weighted Average):\")\n",
    "    print(f\"{'='*50}\")\n",
    "    print(f\"\\nPrimary Prediction (6 numbers): {predicted_numbers}\")\n",
    "    print(f\"\\nAlternative Pool (12 numbers): {predicted_numbers_12}\")\n",
    "    \n",
    "    # Calculate confidence scores\n",
    "    for num in predicted_numbers:\n",
    "        idx = num - 1\n",
    "        print(f\"Number {num:2d}: Confidence {ensemble_prediction[idx]:.4f} ({ensemble_prediction[idx]*100:.2f}%)\")"
   ]
