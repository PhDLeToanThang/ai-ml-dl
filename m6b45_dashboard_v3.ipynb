   "source": [
    "# Mega 6/45 Lottery Analytics Dashboard v3.0\n",
    "## Advanced Statistical Analysis & Prediction System\n",
    "\n",
    "This notebook provides:\n",
    "- **Data Import & Preprocessing**: Load and clean historical lottery data\n",
    "- **Descriptive Statistics**: Frequency analysis, distribution patterns\n",
    "- **Advanced Algorithms**:\n",
    "  - Frequency Distribution Analysis\n",
    "  - Number Pair Co-occurrence Matrix\n",
    "  - Gap Analysis (skips between occurrences)\n",
    "  - Statistical Probability Models\n",
    "  - Machine Learning Predictions\n",
    "- **Visualizations**: Comprehensive charts and heatmaps\n",
    "- **Predictions**: Multi-algorithm ensemble predictions"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Import Libraries & Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from scipy import stats\n",
    "from scipy.stats import chi2_contingency, entropy\n",
    "from collections import Counter, defaultdict\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Machine Learning libraries\n",
    "from sklearn.preprocessing import MinMaxScaler\n",
    "from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier\n",
    "from sklearn.neural_network import MLPClassifier\n",
    "from sklearn.model_selection import train_test_split\n",
    "import itertools\n",
    "\n",
    "# Visualization settings\n",
    "plt.style.use('seaborn-v0_8-darkgrid')\n",
    "sns.set_palette('husl')\n",
    "plt.rcParams['figure.figsize'] = (16, 10)\n",
    "plt.rcParams['font.size'] = 10\n",
    "\n",
    "print(\"✓ All libraries imported successfully\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Data Loading & Preprocessing"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load data\n",
    "file_path = r'C:\\Python311\\m6b45\\mega6b45.csv'\n",
    "df = pd.read_csv(file_path)\n",
    "\n",
    "print(f\"Dataset shape: {df.shape}\")\n",
    "print(f\"\\nFirst 5 rows:\")\n",
    "print(df.head())\n",
    "print(f\"\\nColumn names: {df.columns.tolist()}\")\n",
    "print(f\"\\nData types:\\n{df.dtypes}\")\n",
    "print(f\"\\nMissing values:\\n{df.isnull().sum()}\")\n",
    "\n",
    "# Extract numbers\n",
    "number_columns = ['s1', 's2', 's3', 's4', 's5', 's6']\n",
    "all_numbers = df[number_columns].values.flatten()\n",
    "all_numbers = all_numbers[~np.isnan(all_numbers)].astype(int)\n",
    "\n",
    "print(f\"\\nTotal numbers analyzed: {len(all_numbers)}\")\n",
    "print(f\"Number range: {all_numbers.min()} - {all_numbers.max()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Frequency Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Overall frequency distribution\n",
    "frequency_count = Counter(all_numbers)\n",
    "total_draws = len(df) * 6\n",
    "\n",
    "# Create frequency dataframe\n",
    "freq_df = pd.DataFrame({\n",
    "    'Number': sorted(frequency_count.keys()),\n",
    "    'Frequency': [frequency_count[n] for n in sorted(frequency_count.keys())],\n",
    "    'Probability': [frequency_count[n] / total_draws for n in sorted(frequency_count.keys())]\n",
    "})\n",
    "\n",
    "freq_df['Relative_Frequency_%'] = (freq_df['Frequency'] / freq_df['Frequency'].sum() * 100).round(2)\n",
    "freq_df['Expected_Frequency'] = total_draws / 45\n",
    "freq_df['Chi_Squared'] = ((freq_df['Frequency'] - freq_df['Expected_Frequency']) ** 2) / freq_df['Expected_Frequency']\n",
    "\n",
    "print(\"\\n=== FREQUENCY ANALYSIS ===\")\n",
    "print(freq_df.sort_values('Frequency', ascending=False).head(15))\n",
    "print(f\"\\nTotal Chi-Squared: {freq_df['Chi_Squared'].sum():.2f}\")\n",
    "print(f\"Mean Frequency: {freq_df['Frequency'].mean():.2f}\")\n",
    "print(f\"Std Dev Frequency: {freq_df['Frequency'].std():.2f}\")\n",
    "print(f\"Coefficient of Variation: {(freq_df['Frequency'].std() / freq_df['Frequency'].mean() * 100):.2f}%\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Gap Analysis (Last Appearance Analysis)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def analyze_gaps(df, number_cols):\n",
    "    \"\"\"\n",
    "    Analyze gaps (draws since last appearance) for each number\n",
    "    This helps identify cold numbers and hot numbers\n",
    "    \"\"\"\n",
    "    total_draws = len(df)\n",
    "    gap_data = {}\n",
    "    \n",
    "    for num in range(1, 46):\n",
    "        # Find all draws where this number appeared\n",
    "        appearances = []\n",
    "        for idx, row in df.iterrows():\n",
    "            if num in row[number_cols].values:\n",
    "                appearances.append(idx)\n",
    "        \n",
    "        if appearances:\n",
    "            # Calculate gaps between appearances\n",
    "            gaps = []\n",
    "            for i in range(1, len(appearances)):\n",
    "                gaps.append(appearances[i] - appearances[i-1])\n",
    "            \n",
    "            # Gap since last appearance\n",
    "            gap_since_last = total_draws - 1 - appearances[-1]\n",
    "            \n",
    "            gap_data[num] = {\n",
    "                'last_appearance': appearances[-1],\n",
    "                'gap_since_last': gap_since_last,\n",
    "                'avg_gap': np.mean(gaps) if gaps else 0,\n",
    "                'max_gap': np.max(gaps) if gaps else 0,\n",
    "                'min_gap': np.min(gaps) if gaps else 0,\n",
    "                'frequency': len(appearances),\n",
    "                'appearances': appearances\n",
    "            }\n",
    "    \n",
    "    return gap_data\n",
    "\n",
    "gap_analysis = analyze_gaps(df, number_columns)\n",
    "\n",
    "# Create gap dataframe\n",
    "gap_df = pd.DataFrame([\n",
    "    {'Number': num, **gap_analysis[num]}\n",
    "    for num in sorted(gap_analysis.keys())\n",
    "])\n",
    "\n",
    "print(\"\\n=== GAP ANALYSIS (Cold vs Hot Numbers) ===\")\n",
    "print(\"\\nMost Overdue Numbers (Largest gap since last appearance):\")\n",
    "print(gap_df.nlargest(10, 'gap_since_last')[['Number', 'gap_since_last', 'avg_gap', 'frequency']])\n",
    "\n",
    "print(\"\\n\\nMost Hot Numbers (Recently appeared):\")\n",
    "print(gap_df.nsmallest(10, 'gap_since_last')[['Number', 'gap_since_last', 'avg_gap', 'frequency']])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Number Pair Co-occurrence Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyze which numbers appear together frequently\ndef analyze_number_pairs(df, number_cols):\n",
    "    \"\"\"\n",
    "    Calculate co-occurrence frequency of number pairs\n",
    "    \"\"\"\n",
    "    pair_count = defaultdict(int)\n",
    "    \n",
    "    for idx, row in df.iterrows():\n",
    "        numbers = sorted([int(x) for x in row[number_cols] if not pd.isna(x)])\n",
    "        # Get all combinations of 2 numbers\n",
    "        pairs = list(itertools.combinations(numbers, 2))\n",
    "        for pair in pairs:\n",
    "            pair_count[pair] += 1\n",
    "    \n",
    "    return pair_count\n",
    "\n",
    "pair_count = analyze_number_pairs(df, number_columns)\n",
    "\n",
    "# Top pairs\n",
    "top_pairs = sorted(pair_count.items(), key=lambda x: x[1], reverse=True)[:20]\n",
    "\n",
    "print(\"\\n=== TOP 20 NUMBER PAIRS (Co-occurrence) ===\")\n",
    "for pair, count in top_pairs:\n",
    "    print(f\"Pair {pair[0]:2d}-{pair[1]:2d}: {count:3d} times\")\n",
    "\n",
    "# Create pair frequency matrix\n",
    "pair_matrix = np.zeros((45, 45))\n",
    "for (n1, n2), count in pair_count.items():\n",
    "    pair_matrix[n1-1, n2-1] = count\n",
    "    pair_matrix[n2-1, n1-1] = count"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Statistical Distribution Tests"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test for randomness and uniformity\nprint(\"\\n=== STATISTICAL DISTRIBUTION TESTS ===\")\n",
    "\n",
    "# Chi-squared goodness of fit test\nfreqs = freq_df['Frequency'].values\nchi2_stat, p_value = stats.chisquare(freqs)\nprint(f\"\\n1. Chi-Squared Goodness of Fit Test:\")\nprint(f\"   χ² statistic: {chi2_stat:.4f}\")\nprint(f\"   p-value: {p_value:.6f}\")\nif p_value > 0.05:\n    print(f\"   → Numbers appear UNIFORMLY distributed (p > 0.05)\")\nelse:\n",
    "    print(f\"   → Numbers are BIASED (p < 0.05)\")\n",
    "\n",
    "# Kolmogorov-Smirnov test (uniform distribution)\nks_stat, ks_pvalue = stats.kstest(all_numbers/45, 'uniform')\nprint(f\"\\n2. Kolmogorov-Smirnov Test (Uniform Distribution):\")\nprint(f\"   KS statistic: {ks_stat:.4f}\")\nprint(f\"   p-value: {ks_pvalue:.6f}\")\n",
    "\n",
    "# Entropy analysis\nprobs = freq_df['Probability'].values\nmax_entropy = np.log(45)  # Maximum entropy for 45 numbers\nactual_entropy = entropy(probs)\nnormalized_entropy = actual_entropy / max_entropy\n",
    "\n",
    "print(f\"\\n3. Entropy Analysis (Randomness):\")\nprint(f\"   Maximum Entropy (perfect randomness): {max_entropy:.4f}\")\nprint(f\"   Actual Entropy: {actual_entropy:.4f}\")\nprint(f\"   Normalized Entropy: {normalized_entropy:.4f}\")\nif normalized_entropy > 0.95:\n",
    "    print(f\"   → Data is HIGHLY RANDOM\")\nelif normalized_entropy > 0.85:\n",
    "    print(f\"   → Data is RANDOM\")\nelse:\n",
    "    print(f\"   → Data shows PATTERNS\")\n",
    "\n",
    "# Z-score analysis\nfreq_zscore = np.abs(stats.zscore(freq_df['Frequency'].values))\noutliers = np.sum(freq_zscore > 2)\nprint(f\"\\n4. Outlier Analysis (Numbers with unusual frequency):\")\nprint(f\"   Numbers with |Z-score| > 2: {outliers}\")\nprint(f\"   Outlier Numbers: {freq_df[freq_zscore > 2]['Number'].tolist()}\")"
   ]
  },
