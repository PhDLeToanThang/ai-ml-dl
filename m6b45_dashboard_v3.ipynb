   "source": [
    "print(\"\\n=== STATISTICAL PREDICTION METHOD ===\")\n",
    "print(\"\\nBased on: Frequency × Overdue Score × Pair Correlation\")\n",
    "\n",
    "# Calculate prediction score for each number\nscores = {}\n",
    "\nfor num in range(1, 46):\n",
    "    idx = num - 1\n",
    "    \n",
    "    # 1. Frequency score (normalized)\n",
    "    freq_score = freq_df.loc[freq_df['Number'] == num, 'Relative_Frequency_%'].values[0]\n",
    "    \n",
    "    # 2. Overdue score (numbers not appearing for long time are due)\n",
    "    gap = gap_df.loc[gap_df['Number'] == num, 'gap_since_last'].values[0]\n",
    "    avg_gap = gap_df.loc[gap_df['Number'] == num, 'avg_gap'].values[0]\n",
    "    overdue_score = (gap / (avg_gap + 1)) * 20  # Scale to 0-20\n",
    "    \n",
    "    # 3. Pair correlation (tendency to appear with hot numbers)\n",
    "    pair_score = 0\n",
    "    for pair, count in list(sorted(pair_count.items(), key=lambda x: x[1], reverse=True)[:10]):\n",
    "        if num in pair:\n",
    "            pair_score += count / 10\n",
    "    \n",
    "    # Combined score\n",
    "    combined_score = (freq_score * 0.4) + (overdue_score * 0.4) + (pair_score * 0.2)\n",
    "    scores[num] = {\n",
    "        'frequency_score': freq_score,\n",
    "        'overdue_score': overdue_score,\n",
    "        'pair_score': pair_score,\n",
    "        'combined_score': combined_score\n",
    "    }\n",
    "\n",
    "# Get top 6 and top 12\nscored_numbers = sorted(scores.items(), key=lambda x: x[1]['combined_score'], reverse=True)\ntop_6_statistical = sorted([num for num, _ in scored_numbers[:6]])\ntop_12_statistical = sorted([num for num, _ in scored_numbers[:12]])\n",
    "\n",
    "print(f\"\\nTop 6 (Statistical): {top_6_statistical}\")\nprint(f\"Top 12 (Statistical): {top_12_statistical}\")\n",
    "\n",
    "print(f\"\\nDetailed Scores for Top 15:\")\nprint(f\"{'Num':>3} {'Freq%':>7} {'Overdue':>8} {'Pair':>6} {'Total':>8}\")\nprint(f\"{'-'*35}\")\nfor num, scores_dict in scored_numbers[:15]:\n",
    "    print(f\"{num:3d} {scores_dict['frequency_score']:7.2f} {scores_dict['overdue_score']:8.2f} \"\n",
